# API Control de Notas (UMG). El path /api/* va incluido en cada endpoint del config.
VITE_API_URL=https://notas.digicom.com.gt

# DEV ONLY — login automático con un usuario mock (rol admin).
# Pon en false para usar el formulario real de login por ID.
VITE_DEV_AUTH_BYPASS=false

# DEV ONLY — ID que se usa cuando VITE_DEV_AUTH_BYPASS=true
VITE_DEV_USUARIO_ID=1
